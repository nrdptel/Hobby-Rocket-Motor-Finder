Thumbs.db

# Data files that ARE tracked:
#   snapshot.example.json    — frozen seed so `npm run dev` works on a fresh clone
#   snapshot.json            — committed hourly by .github/workflows/scrape.yml
#                              (Vercel auto-deploys when it changes)
#   thrustcurve_aerotech.json — refreshable but slow-changing catalog
data/*.db
data/*.db-journal
data/snapshots/
# Transient CI health report consumed by the scrape alerting step.
data/scrape-status.json

# IDE
.vscode/
.idea/

# Claude Code per-machine settings (commit .claude/settings.json if needed; never local)
.claude/settings.local.json

# Design sources (Illustrator) — keep the exported SVG, not the binary
*.ai
*.AI
