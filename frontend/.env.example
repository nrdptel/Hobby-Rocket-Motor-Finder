# Restock email-alerts configuration (OPTIONAL).
#
# The site runs fully without any of this — the alert backend is gated on these
# vars, and when they're unset the API routes return 503 and the UI hides the 🔔
# button (so a fork works with zero setup). Set them only if you want the
# "email me when it's back in stock" feature. Copy to `.env.local` for local
# dev, or set them in your host's env (e.g. Vercel) for production.
#
# Full walkthrough (ZeptoMail + Upstash + Vercel + GitHub Actions setup):
# see ../docs/email-alerts.md.

# --- Email sending (ZeptoMail) ---
# The "Send Mail" token — the full `Zoho-enczapikey …` value. Treat as a live
# credential (it can send mail as your domain); never commit the real value.
ZEPTOMAIL_TOKEN=
# Optional API host; defaults to api.zeptomail.com (use api.zeptomail.eu for EU).
ZEPTOMAIL_HOST=
# From address on your verified domain, e.g. "HPR Motor Finder <alerts@example.com>".
ALERTS_FROM=
# Optional shared secret for the ZeptoMail bounce/complaint webhook.
ZEPTOMAIL_WEBHOOK_SECRET=

# --- Subscriber store (Upstash Redis, free tier) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Secrets (generate random hex, e.g. `openssl rand -hex 32`) ---
# Signs the confirm/unsubscribe/manage magic-link tokens.
ALERTS_SECRET=
# Bearer secret the hourly scrape uses to call /api/alerts/dispatch. Must match
# the value set as a GitHub Actions secret (see below).
ALERTS_DISPATCH_SECRET=

# --- Public (exposed to the browser) ---
# "1" shows the 🔔 alert button in the UI.
NEXT_PUBLIC_ALERTS_ENABLED=
# Canonical site origin, used for absolute links in emails and metadata.
NEXT_PUBLIC_SITE_URL=https://motor.fusionspace.co

# --- Backend / GitHub Actions (NOT read by the frontend) ---
# The hourly scrape (.github/workflows/scrape.yml) POSTs restocks to the dispatch
# route. Set these as GitHub Actions repo secrets, not here:
#   ALERTS_DISPATCH_URL    = https://<your-site>/api/alerts/dispatch
#   ALERTS_DISPATCH_SECRET = same value as ALERTS_DISPATCH_SECRET above
