# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# Snapshot files copied in by scripts/copy-snapshot.mjs at predev/prebuild.
# Source of truth lives in <repo>/data/ — these are working copies only.
/data/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# cloudflare / wrangler
.wrangler

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Build-time generated static assets (regenerated by prebuild scripts from the
# bundled data): the client compare payload, the pre-rendered OG images, and the
# public JSON API.
/public/compare-data.json
/public/og/
/public/api/
