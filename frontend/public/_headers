# Cloudflare Pages response headers. Replaces the next.config.ts headers() block,
# which static export can't emit. Same baseline security headers, applied to
# every path: clickjacking, MIME sniffing, and referrer leakage. (No CSP — see
# the note in the original next.config.ts: the inline theme-init script would
# need a per-request nonce/hash and a misconfigured CSP failing closed is a worse
# risk than its marginal benefit here.)
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# The service worker must always be revalidated so a fresh build's worker is
# picked up promptly — a cached sw.js would strand installed users on an old
# version (the in-app "newer snapshot" prompt still depends on this fetch).
/sw.js
  Cache-Control: no-cache

# Bulk availability feed (public/availability.json, generated by gen-api.mjs).
# Muster (muster.fusionspace.co) fetches this one static file cross-origin to
# badge whole motor lists in a single request. It lives at the site ROOT, so —
# unlike /api/* below — it does NOT inherit that block's CORS; set it here too.
# Same ~10 min cache as the API (refreshed on the ~hourly deploy).
/availability.json
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, OPTIONS
  Cache-Control: public, max-age=600

# Public read-only JSON API (static files generated by scripts/gen-api.mjs).
# CORS-open so any site can fetch it from the browser; cached ~10 min (the data
# refreshes on the ~hourly deploy, which also invalidates the edge copy).
/api/*
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, OPTIONS
  Cache-Control: public, max-age=600

